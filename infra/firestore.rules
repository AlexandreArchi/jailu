rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount'])
      );

      match /books/{bookId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /following/{followedUid} {
        allow read: if request.auth != null &&
          (request.auth.uid == userId || request.auth.uid == followedUid);
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /followers/{followerUid} {
        allow read: if request.auth != null &&
          (request.auth.uid == userId || request.auth.uid == followerUid);
        allow write: if request.auth != null && request.auth.uid == followerUid;
      }

      match /followRequests/{requesterUid} {
        allow read: if request.auth != null &&
          (request.auth.uid == userId || request.auth.uid == requesterUid);
        allow create: if request.auth != null && request.auth.uid == requesterUid;
        allow delete: if request.auth != null &&
          (request.auth.uid == userId || request.auth.uid == requesterUid);
      }

      match /friends/{friendUid} {
        allow read: if request.auth != null &&
          (request.auth.uid == userId || request.auth.uid == friendUid);
        allow write: if request.auth != null &&
          (request.auth.uid == userId || request.auth.uid == friendUid);
      }

      match /notifications/{notifId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        // Seul l'auteur peut créer une notif en son propre nom
        allow create: if request.auth != null
          && request.resource.data.fromUid == request.auth.uid;
      }

      match /recommendations/{recId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        // Seul l'auteur peut envoyer une reco en son propre nom
        allow create: if request.auth != null
          && request.resource.data.fromUid == request.auth.uid;
      }

      match /stories/{storyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if request.auth != null &&
          exists(/databases/$(database)/documents/users/$(userId)/followers/$(request.auth.uid));
      }

      match /friendRequests/{fromUid} {
        allow read: if request.auth != null &&
          (request.auth.uid == userId || request.auth.uid == fromUid);
        allow create: if request.auth != null && request.auth.uid == fromUid;
        allow delete: if request.auth != null &&
          (request.auth.uid == userId || request.auth.uid == fromUid);
      }
    }
  }
}
