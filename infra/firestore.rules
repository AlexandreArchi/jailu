rules_version = '2'; // v2

service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      // Lecture publique (pages /u/:username sans auth) + tout utilisateur connecté
      allow read: if true;
      // Seul le propriétaire peut créer/modifier son profil
      allow create, update: if request.auth != null && request.auth.uid == userId;

      match /books/{bookId} {
        // Lecture publique (le client filtre sur status == 'read' pour les profils publics)
        allow read: if true;
        // Écriture réservée au propriétaire
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /friends/{friendUid} {
        // Le propriétaire et l'ami peuvent lire
        allow read: if request.auth != null &&
          (request.auth.uid == userId || request.auth.uid == friendUid);
        // Le propriétaire ou l'ami peuvent écrire (acceptation bilatérale via batch)
        allow write: if request.auth != null &&
          (request.auth.uid == userId || request.auth.uid == friendUid);
      }

      match /recommendations/{recId} {
        // Seul le destinataire peut lire et supprimer
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        // N'importe quel utilisateur connecté peut envoyer (seuls les amis voient les profils dans l'app)
        allow create: if request.auth != null;
      }

      match /stories/{storyId} {
        // Le propriétaire peut tout faire
        allow read, write: if request.auth != null && request.auth.uid == userId;
        // Les amis confirmés peuvent lire
        allow read: if request.auth != null &&
          exists(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid));
      }

      match /friendRequests/{fromUid} {
        // Le destinataire et l'expéditeur peuvent lire
        allow read: if request.auth != null &&
          (request.auth.uid == userId || request.auth.uid == fromUid);
        // Seul l'expéditeur peut créer
        allow create: if request.auth != null && request.auth.uid == fromUid;
        // L'un ou l'autre peut supprimer (accepter/refuser/annuler)
        allow delete: if request.auth != null &&
          (request.auth.uid == userId || request.auth.uid == fromUid);
      }
    }
  }
}
